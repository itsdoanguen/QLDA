{
  "name": "@land-registry/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/main.ts",
    "build": "tsc -p tsconfig.build.json",
    "lint": "node -e \"console.log('api: lint baseline pending')\"",
    "test": "node -e \"console.log('api: test baseline pending')\"",
    "db:migrate:up": "typeorm-ts-node-commonjs -d src/database/data-source.ts migration:run",
    "db:migrate:down": "typeorm-ts-node-commonjs -d src/database/data-source.ts migration:revert",
    "db:migrate:status": "typeorm-ts-node-commonjs -d src/database/data-source.ts migration:show",
    "seed:admin": "ts-node scripts/seed-admin.ts"
  },
  "dependencies": {
    "@land-registry/shared-types": "*",
    "@nestjs/common": "^10.4.7",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.7",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/platform-express": "^10.4.7",
    "@nestjs/swagger": "^7.4.2",
    "@nestjs/typeorm": "^10.0.2",
    "axios": "^1.15.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "dotenv": "^16.4.7",
    "ethers": "^6.13.5",
    "form-data": "^4.0.5",
    "pg": "^8.13.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "swagger-ui-express": "^5.0.1",
    "typeorm": "^0.3.20",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@nestjs/testing": "^10.4.22",
    "@types/express": "^5.0.1",
    "@types/jest": "^30.0.0",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.13.10",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typeorm-ts-node-commonjs": "^0.3.20",
    "typescript": "^5.8.2"
  }
}
